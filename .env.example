# SwarmDev v3 — API Keys
# Copy this file to .env and fill in your keys.
# Both are FREE — takes about 2 minutes each.

# ── Groq (fast code generation) ───────────────────────────────────────────────
# Sign up: https://console.groq.com  → API Keys → Create
# Best model: llama-3.3-70b-versatile
GROQ_API_KEY=your_groq_key_here

# ── Google Gemini (long context, architecture + docs) ─────────────────────────
# Sign up: https://aistudio.google.com/app/apikey → Create API Key
# Best model: gemini-2.0-flash
GOOGLE_API_KEY=your_google_api_key_here

# ── Optional ──────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...   (alias for GOOGLE_API_KEY)
